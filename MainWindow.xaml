<Window x:Class="AlarmClock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AlarmClock"
        mc:Ignorable="d"
        Title="Weckuhr" Height="520" Width="440"
        ResizeMode="NoResize"
        Background="#1E1E2E">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Aktuelle Uhrzeit -->
        <TextBlock x:Name="CurrentTimeText"
                   Grid.Row="0"
                   Text="00:00:00"
                   FontSize="64"
                   FontWeight="Bold"
                   Foreground="#CDD6F4"
                   HorizontalAlignment="Center"
                   FontFamily="Consolas"
                   Margin="0,10,0,4"/>

        <!-- Datum -->
        <TextBlock x:Name="CurrentDateText"
                   Grid.Row="1"
                   Text=""
                   FontSize="15"
                   Foreground="#A6ADC8"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,24"/>

        <!-- Weckzeit einstellen -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,14">
            <TextBlock Text="Weckzeit:"
                       Foreground="#CDD6F4"
                       FontSize="15"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>
            <TextBox x:Name="AlarmTimePicker"
                     Width="110"
                     FontSize="15"
                     Background="#313244"
                     Foreground="#CDD6F4"
                     BorderBrush="#585B70"
                     Text="07:00"
                     TextAlignment="Center"
                     VerticalContentAlignment="Center"
                     Height="32"/>
        </StackPanel>

        <!-- Ton-Auswahl -->
        <Grid Grid.Row="3" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Weckton:"
                       Foreground="#CDD6F4"
                       FontSize="15"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       Grid.Column="0"/>
            <ComboBox x:Name="SoundComboBox"
                      Grid.Column="1"
                      FontSize="14"
                      Background="#313244"
                      Foreground="#CDD6F4"
                      BorderBrush="#585B70"
                      Height="32"
                      SelectionChanged="SoundComboBox_SelectionChanged"/>
        </Grid>

        <!-- Radiosender (nur sichtbar wenn Radio gewählt) -->
        <Grid Grid.Row="4" Margin="0,0,0,14" x:Name="RadioPanel" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Sender:"
                       Foreground="#CDD6F4"
                       FontSize="15"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       Grid.Column="0"/>
            <ComboBox x:Name="RadioComboBox"
                      Grid.Column="1"
                      FontSize="14"
                      Background="#313244"
                      Foreground="#CDD6F4"
                      BorderBrush="#585B70"
                      Height="32"/>
        </Grid>

        <!-- Status -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="5"
                   Text="Kein Alarm gesetzt"
                   FontSize="14"
                   Foreground="#A6E3A1"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"
                   TextWrapping="Wrap"
                   TextAlignment="Center"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="SetAlarmButton"
                    Content="⏰ Alarm setzen"
                    Width="150" Height="40"
                    Margin="0,0,15,0"
                    Background="#89B4FA"
                    Foreground="#1E1E2E"
                    FontWeight="Bold"
                    FontSize="14"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="SetAlarmButton_Click"/>
            <Button x:Name="StopAlarmButton"
                    Content="🛑 Alarm stoppen"
                    Width="150" Height="40"
                    Background="#F38BA8"
                    Foreground="#1E1E2E"
                    FontWeight="Bold"
                    FontSize="14"
                    BorderThickness="0"
                    Cursor="Hand"
                    IsEnabled="False"
                    Click="StopAlarmButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
